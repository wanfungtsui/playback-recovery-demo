# Optional: the demo uses validated fallback playbooks when this is empty.
AGENT_API_KEY=

# OpenAI-compatible chat-completions endpoint and model.
AGENT_API_URL=https://api.openai.com/v1/chat/completions
AGENT_MODEL=gpt-4o-mini

# Optional: durable Operations run history through Vercel Upstash Redis.
# The Marketplace integration injects these names automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
